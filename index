<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>Campsite Dogs v5</title>
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#3f6b3f">
<style>
:root{--green:#3f6b3f;--cream:#fff8e8;--dark:#263522}
*{box-sizing:border-box;user-select:none;-webkit-user-select:none}
body{margin:0;font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:linear-gradient(#dff2da,#b9dfae);color:var(--dark);overflow:hidden}
header{padding:10px 12px;background:var(--green);color:white;display:flex;justify-content:space-between;align-items:center;gap:8px}
h1{margin:0;font-size:20px}
button{border:0;border-radius:10px;background:#f7d77b;padding:9px 12px;font-weight:800;color:#342a11}
#info{padding:7px 10px;background:#fff8e8;font-size:13px;text-align:center}
#game{position:relative;width:100vw;height:calc(100vh - 108px);background:radial-gradient(circle at 50% 48%,rgba(255,255,255,.33) 0 110px,transparent 111px),linear-gradient(#c7e7bd,#9fce8f);touch-action:none;overflow:hidden}
svg#leashes{position:absolute;inset:0;width:100%;height:100%;z-index:1;pointer-events:none}
.leashPath{fill:none;stroke:#27313a;stroke-width:4;stroke-linecap:round;stroke-linejoin:round;opacity:.75}
.leashPath.furnitureTangled{stroke:#b0362f;stroke-width:5;opacity:.9}
.leashPath.dogTangled{stroke:#8a35b1;stroke-width:5;opacity:.95;stroke-dasharray:8 5}
.stake{position:absolute;width:18px;height:18px;border-radius:50%;background:#6b4128;border:3px solid #3b2416;transform:translate(-50%,-50%);z-index:3}
.dog{position:absolute;width:66px;height:50px;transform:translate(-50%,-50%);z-index:6;text-align:center;touch-action:none}
.dog.dragging{filter:drop-shadow(0 0 12px #fff);z-index:9}
.dog .body{width:56px;height:32px;border-radius:22px 22px 18px 18px;position:absolute;left:4px;top:12px;box-shadow:inset 0 -4px rgba(0,0,0,.15)}
.dog .head{width:30px;height:28px;border-radius:50%;position:absolute;right:-2px;top:1px;box-shadow:inset 0 -3px rgba(0,0,0,.13)}
.dog .ear{width:11px;height:18px;border-radius:9px;position:absolute;top:0}
.dog .ear.left{right:18px;transform:rotate(-28deg)}
.dog .ear.right{right:1px;transform:rotate(28deg)}
.dog .tail{width:22px;height:8px;border-radius:8px;position:absolute;left:-8px;top:17px;transform:rotate(-25deg)}
.dog .legs{position:absolute;left:13px;top:38px;font-size:14px;letter-spacing:6px}
.dog .face{position:absolute;right:4px;top:8px;font-size:11px;color:white}
.dog .name{position:absolute;left:50%;transform:translateX(-50%);top:-16px;background:white;border-radius:999px;padding:1px 7px;font-size:12px;font-weight:900;white-space:nowrap;box-shadow:0 1px 4px rgba(0,0,0,.18)}
.black .body,.black .head,.black .ear,.black .tail{background:#151515}
.brown .body,.brown .head,.brown .ear,.brown .tail{background:#8b5a2b}
.corgi .body{height:26px;top:18px;width:58px}.corgi .legs{top:40px;font-size:10px}
.coton .body,.coton .head,.coton .ear,.coton .tail{background:#f6f1e8;border:1px solid #d9d3c8}.coton .face{color:#333}
.obstacle{position:absolute;z-index:4;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:900;box-shadow:0 5px 0 rgba(0,0,0,.18);touch-action:none;border:2px solid rgba(0,0,0,.12)}
.chair{width:70px;height:58px;background:#dfad68}.table{width:112px;height:72px;background:#b57b48}.cooler{width:76px;height:54px;background:#6ab7d8}.tent{width:104px;height:78px;background:#e9865c;clip-path:polygon(50% 0,100% 100%,0 100%);border:0}.fire{width:72px;height:72px;border-radius:50%;background:#5a4a3c;color:#ffcf55}
#panel{position:absolute;bottom:10px;left:10px;right:10px;background:rgba(255,248,232,.95);border-radius:14px;padding:10px;z-index:10;box-shadow:0 3px 10px rgba(0,0,0,.18)}
#whineOuter{height:14px;background:#e1d8c4;border-radius:999px;overflow:hidden}
#whine{height:100%;width:0%;background:#c84b40;transition:width .12s linear}
#status{font-size:14px;margin-top:6px;font-weight:800;min-height:34px}
#mini{font-size:12px;opacity:.8;margin-top:2px}
</style>
</head>
<body>
<header><h1>🏕️ Campsite Dogs</h1><button id="newGame">New Game</button></header>
<div id="info">Drag dogs around each other and around furniture to remove crossings. Purple = dog-leash tangle. Red = furniture wrap.</div>
<main id="game">
  <svg id="leashes"></svg>
  <div id="panel">
    <div id="whineOuter"><div id="whine"></div></div>
    <div id="status">Loading campsite...</div>
    <div id="mini">Dog order: Reba, Mollye, Stella, Percy, Lizzie</div>
  </div>
</main>
<script>
const DOGS=[
{name:"Reba",breed:"brown corgi",className:"dog brown corgi",speed:.85,leash:150,patience:.75},
{name:"Mollye",breed:"brown German Shepherd",className:"dog brown",speed:1.25,leash:165,patience:1.2},
{name:"Stella",breed:"black lab",className:"dog black",speed:1.08,leash:165,patience:1.0},
{name:"Percy",breed:"Coton",className:"dog coton",speed:1.38,leash:155,patience:1.35},
{name:"Lizzie",breed:"black lab",className:"dog black",speed:1.15,leash:170,patience:1.1}
];
const game=document.getElementById("game"), leashSvg=document.getElementById("leashes"), whine=document.getElementById("whine"), statusEl=document.getElementById("status");
let level=1,dogs=[],obstacles=[],dragging=null,dragType=null,offX=0,offY=0,whineMeter=0,warnings=0,loop=null,last=performance.now(),clearTime=0;
function rand(a,b){return a+Math.random()*(b-a)} function distance(a,b,c,d){return Math.hypot(a-c,b-d)}
function ccw(A,B,C){return (C.y-A.y)*(B.x-A.x)>(B.y-A.y)*(C.x-A.x)}
function segmentsIntersect(A,B,C,D){return ccw(A,C,D)!=ccw(B,C,D)&&ccw(A,B,C)!=ccw(A,B,D)}
function clearGame(){[...game.querySelectorAll(".dog,.stake,.obstacle")].forEach(e=>e.remove());leashSvg.innerHTML="";dogs=[];obstacles=[];whineMeter=0;warnings=0;clearTime=0}
function startGame(){level=1;buildLevel()}
function buildLevel(){
 clearGame();
 const w=game.clientWidth,h=game.clientHeight,cx=w*.5,cy=h*.43;
 const stakePositions=[[cx-45,cy-42],[cx+45,cy-42],[cx-55,cy+42],[cx+55,cy+42],[cx,cy+88]];
 const dogStarts=[[cx+55,cy+20],[cx-40,cy+25],[cx+20,cy-55],[cx-75,cy-10],[cx+78,cy-18]];
 DOGS.slice(0,level).forEach((d,i)=>{
  const [sx,sy]=stakePositions[i], [x,y]=dogStarts[i];
  const stake=document.createElement("div"); stake.className="stake"; stake.style.left=sx+"px"; stake.style.top=sy+"px"; game.appendChild(stake);
  const path=document.createElementNS("http://www.w3.org/2000/svg","path"); path.setAttribute("class","leashPath"); leashSvg.appendChild(path);
  const dog=document.createElement("div"); dog.className=d.className; dog.innerHTML=`<div class="name">${d.name}</div><div class="tail"></div><div class="body"></div><div class="head"></div><div class="ear left"></div><div class="ear right"></div><div class="face">● ●<br>ᴥ</div><div class="legs">▌▌</div>`;
  dog.addEventListener("pointerdown",startDragDog); game.appendChild(dog);
  dogs.push({...d,el:dog,path,stakeX:sx,stakeY:sy,x,y,tx:x+rand(-50,50),ty:y+rand(-50,50),wrapped:[],dogTangled:false,held:false});
 });
 const obs=[["chair","🪑",cx-130,cy+15],["table","▤",cx+85,cy+22],["cooler","🧊",cx-20,cy-105],["tent","",cx+120,cy-92],["fire","🔥",cx-112,cy-78]].slice(0,Math.min(level+1,5));
 obs.forEach(([cls,label,x,y],idx)=>{const ob=document.createElement("div"); ob.className="obstacle "+cls; ob.textContent=label; ob.dataset.id=idx; ob.style.left=x+"px"; ob.style.top=y+"px"; ob.addEventListener("pointerdown",startDragObstacle); game.appendChild(ob); obstacles.push(ob)});
 if(loop) cancelAnimationFrame(loop); last=performance.now(); loop=requestAnimationFrame(tick);
}
function startDragObstacle(e){dragging=e.currentTarget;dragType="obstacle";dragging.setPointerCapture(e.pointerId);const r=dragging.getBoundingClientRect();offX=e.clientX-r.left;offY=e.clientY-r.top;dragging.addEventListener("pointermove",moveDrag);dragging.addEventListener("pointerup",endDrag)}
function startDragDog(e){dragging=e.currentTarget;dragType="dog";dragging.classList.add("dragging");dragging.setPointerCapture(e.pointerId);const d=dogs.find(x=>x.el===dragging);d.held=true;const gr=game.getBoundingClientRect();offX=e.clientX-gr.left-d.x;offY=e.clientY-gr.top-d.y;dragging.addEventListener("pointermove",moveDrag);dragging.addEventListener("pointerup",endDrag)}
function moveDrag(e){
 const gr=game.getBoundingClientRect();
 if(dragType==="obstacle"){let x=e.clientX-gr.left-offX,y=e.clientY-gr.top-offY;x=Math.max(0,Math.min(game.clientWidth-dragging.offsetWidth,x));y=Math.max(0,Math.min(game.clientHeight-dragging.offsetHeight,y));dragging.style.left=x+"px";dragging.style.top=y+"px";}
 if(dragType==="dog"){const d=dogs.find(x=>x.el===dragging);let x=e.clientX-gr.left-offX,y=e.clientY-gr.top-offY;const away=distance(x,y,d.stakeX,d.stakeY);if(away>d.leash){const a=Math.atan2(y-d.stakeY,x-d.stakeX);x=d.stakeX+Math.cos(a)*d.leash;y=d.stakeY+Math.sin(a)*d.leash}d.x=Math.max(30,Math.min(game.clientWidth-30,x));d.y=Math.max(30,Math.min(game.clientHeight-105,y));d.tx=d.x;d.ty=d.y;}
}
function endDrag(e){if(dragging){dragging.classList.remove("dragging");dragging.removeEventListener("pointermove",moveDrag);dragging.removeEventListener("pointerup",endDrag)} if(dragType==="dog"){const d=dogs.find(x=>x.el===dragging);if(d)d.held=false} dragging=null;dragType=null}
function obstacleCenter(ob){return{x:ob.offsetLeft+ob.offsetWidth/2,y:ob.offsetTop+ob.offsetHeight/2,r:Math.max(ob.offsetWidth,ob.offsetHeight)/2}}
function lineHitsObstacle(x1,y1,x2,y2,ob){const c=obstacleCenter(ob),dx=x2-x1,dy=y2-y1,len2=dx*dx+dy*dy||1;let t=((c.x-x1)*dx+(c.y-y1)*dy)/len2;t=Math.max(0,Math.min(1,t));const px=x1+t*dx,py=y1+t*dy;return distance(px,py,c.x,c.y)<c.r*.7}
function chooseTarget(d){const a=rand(0,Math.PI*2),r=rand(d.leash*.15,d.leash*.75);d.tx=d.stakeX+Math.cos(a)*r;d.ty=d.stakeY+Math.sin(a)*r}
function moveDogs(dt){dogs.forEach((d,i)=>{if(d.held)return;if(distance(d.x,d.y,d.tx,d.ty)<14||Math.random()<.008)chooseTarget(d);if(d.name==="Lizzie"&&dogs.length>1&&Math.random()<.025){const o=dogs[Math.floor(Math.random()*(dogs.length-1))];d.tx=o.x+rand(-35,35);d.ty=o.y+rand(-35,35)}const a=Math.atan2(d.ty-d.y,d.tx-d.x);d.x+=Math.cos(a)*d.speed*dt*.055;d.y+=Math.sin(a)*d.speed*dt*.055;const away=distance(d.x,d.y,d.stakeX,d.stakeY);if(away>d.leash){const aa=Math.atan2(d.y-d.stakeY,d.x-d.stakeX);d.x=d.stakeX+Math.cos(aa)*d.leash;d.y=d.stakeY+Math.sin(aa)*d.leash;chooseTarget(d)}d.x=Math.max(30,Math.min(game.clientWidth-30,d.x));d.y=Math.max(30,Math.min(game.clientHeight-105,d.y))})}
function updateFurnitureWraps(){
 dogs.forEach(d=>{
  const start=d.wrapped.length?d.wrapped[d.wrapped.length-1]:{x:d.stakeX,y:d.stakeY};
  obstacles.forEach(ob=>{if(d.wrapped.some(w=>w.id===ob.dataset.id))return;if(lineHitsObstacle(start.x,start.y,d.x,d.y,ob)){const c=obstacleCenter(ob);d.wrapped.push({id:ob.dataset.id,x:c.x,y:c.y})}});
  d.wrapped=d.wrapped.filter((wrap,i)=>{const ob=obstacles.find(o=>o.dataset.id===wrap.id);if(!ob)return false;const c=obstacleCenter(ob);wrap.x=c.x;wrap.y=c.y;const prev=i===0?{x:d.stakeX,y:d.stakeY}:d.wrapped[i-1];return lineHitsObstacle(prev.x,prev.y,d.x,d.y,ob)||i<d.wrapped.length-1});
 });
}
function leashSegments(d){const pts=[{x:d.stakeX,y:d.stakeY},...d.wrapped,{x:d.x,y:d.y}],segs=[];for(let i=0;i<pts.length-1;i++)segs.push([pts[i],pts[i+1]]);return segs}
function updateDogCrossings(){
 dogs.forEach(d=>d.dogTangled=false);
 for(let i=0;i<dogs.length;i++)for(let j=i+1;j<dogs.length;j++){
  const aSegs=leashSegments(dogs[i]),bSegs=leashSegments(dogs[j]);
  let crossed=false;
  for(const a of aSegs)for(const b of bSegs){if(segmentsIntersect(a[0],a[1],b[0],b[1]))crossed=true}
  if(crossed){dogs[i].dogTangled=true;dogs[j].dogTangled=true}
 }
}
function drawLeashes(){
 dogs.forEach(d=>{
  const pts=[{x:d.stakeX,y:d.stakeY},...d.wrapped,{x:d.x,y:d.y}];
  d.path.setAttribute("d",pts.map((p,i)=>(i?"L":"M")+p.x.toFixed(1)+" "+p.y.toFixed(1)).join(" "));
  d.path.setAttribute("class",d.dogTangled?"leashPath dogTangled":(d.wrapped.length?"leashPath furnitureTangled":"leashPath"));
  d.el.style.left=d.x+"px";d.el.style.top=d.y+"px";
  d.el.style.filter=(d.dogTangled||d.wrapped.length)?"drop-shadow(0 0 8px #c84b40)":"";
 });
}
function updateWhine(dt){
 const tangled=dogs.filter(d=>d.wrapped.length||d.dogTangled);
 if(tangled.length)whineMeter+=tangled.reduce((a,d)=>a+d.patience+(d.wrapped.length*.4)+(d.dogTangled?.8:0),0)*dt*.01;else whineMeter-=dt*.02;
 whineMeter=Math.max(0,Math.min(100,whineMeter));whine.style.width=whineMeter+"%";
 if(whineMeter>=100){warnings++;whineMeter=25;dogs.forEach(d=>{d.wrapped=[];d.dogTangled=false;chooseTarget(d)});statusEl.textContent=`🚨 Campground host warning ${warnings}/3! Dogs reset.`;if(warnings>=3)setTimeout(buildLevel,900)}
 else if(tangled.length){const dogNames=tangled.map(d=>d.name).join(", ");statusEl.textContent=`${dogNames} tangled! Drag dogs around each other or around furniture to free the leads.`}
 else statusEl.textContent=`Level ${level}: keep ${dogs.map(d=>d.name).join(", ")} from tying the campsite in knots.`;
}
function checkWin(dt){const any=dogs.some(d=>d.wrapped.length||d.dogTangled);if(!any&&whineMeter<10)clearTime+=dt;else clearTime=0;if(clearTime>9000){clearTime=0;if(level<DOGS.length){level++;statusEl.textContent=`Great untangling! ${DOGS[level-1].name} joins next.`;setTimeout(buildLevel,900)}else{statusEl.textContent="🏆 Whole pack untangled! Tap New Game to play again.";cancelAnimationFrame(loop)}}}
function tick(now){const dt=Math.min(40,now-last);last=now;moveDogs(dt);updateFurnitureWraps();updateDogCrossings();drawLeashes();updateWhine(dt);checkWin(dt);loop=requestAnimationFrame(tick)}
document.getElementById("newGame").addEventListener("click",startGame);
if("serviceWorker" in navigator){navigator.serviceWorker.register("service-worker.js").catch(()=>{})}
startGame();
</script>
</body>
</html>
